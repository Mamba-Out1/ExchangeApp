# Local Properties Configuration Template
# Copy this file to local.properties and fill in your API keys
# DO NOT commit local.properties to version control

## SDK Location (if needed)
# sdk.dir=/path/to/Android/sdk

## DashScope/Qwen API Configuration
# Required: Your Alibaba Cloud Model Studio API Key
DASHSCOPE_API_KEY=sk-your-api-key-here

# Optional: OpenAI-compatible DashScope endpoint.
# For workspace regional endpoints, set the base URL that contains /api/v1 or /compatible-mode/.
DASHSCOPE_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/

# Optional: Qwen model name
DASHSCOPE_MODEL=qwen3.7-plus
